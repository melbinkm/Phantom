# Phantom Class B guest kernel configuration — nf_tables fuzzing
# Based on minimal defconfig + networking + nf_tables
CONFIG_64BIT=y
CONFIG_X86_64=y

# CPU
CONFIG_SMP=n
CONFIG_NR_CPUS=1
CONFIG_HYPERVISOR_GUEST=n
CONFIG_PARAVIRT=n

# Preemption / scheduling
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_100=y

# Memory
CONFIG_HIGHMEM64G=n
CONFIG_NUMA=n
CONFIG_MEMORY_HOTPLUG=n
CONFIG_SPARSEMEM_VMEMMAP=y

# Modules (disabled for determinism)
CONFIG_MODULES=n

# Networking — needed for nf_tables
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y

# nf_tables core + expressions (where the bugs live)
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_PAYLOAD=y
CONFIG_NFT_EXTHDR=y
CONFIG_NFT_META=y
CONFIG_NFT_CMP=y
CONFIG_NFT_RANGE=y
CONFIG_NFT_LOOKUP=y
CONFIG_NFT_BITWISE=y
CONFIG_NFT_BYTEORDER=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_REJECT_INET=y
CONFIG_NFT_COMPAT=n
CONFIG_NFT_HASH=y
CONFIG_NFT_NUMGEN=y
CONFIG_NFT_QUOTA=y
CONFIG_NFT_OBJREF=y
CONFIG_NFT_DYNSET=y
CONFIG_NFT_SET_HASH=y
CONFIG_NFT_SET_RBTREE=y
CONFIG_NFT_SET_BITMAP=y
CONFIG_NFT_SET_PIPAPO=y
CONFIG_NFT_CHAIN_NAT=y

# Netlink (implicit with NET but be explicit)
CONFIG_NETLINK_DIAG=n

# Minimal networking — no real network devices needed
CONFIG_UNIX=n
CONFIG_IPV6=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_NETDEVICES=n

# Block / storage (disabled)
CONFIG_BLOCK=n
CONFIG_BLK_DEV_INITRD=n

# Filesystems (disabled)
CONFIG_EXT4_FS=n
CONFIG_PROC_FS=y
CONFIG_SYSFS=n
CONFIG_TMPFS=n

# Randomisation (disabled for determinism)
CONFIG_RANDOMIZE_BASE=n
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=n
CONFIG_SLAB_FREELIST_RANDOM=n
CONFIG_SLAB_FREELIST_HARDENED=n
CONFIG_SHUFFLE_PAGE_ALLOCATOR=n
CONFIG_RANDOM_TRUST_CPU=n
CONFIG_RANDOM_TRUST_BOOTLOADER=n

# KASAN — disabled for performance; enable for bug diagnosis
CONFIG_KASAN=n

# Printk / early boot output
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_EARLY_PRINTK_DBGP=n

# Debug info for crash analysis
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF4=y
CONFIG_FRAME_POINTER=y
CONFIG_STACKTRACE=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=0

# Serial / console (minimal)
CONFIG_TTY=y
CONFIG_SERIAL_8250=n
CONFIG_VIRTIO_CONSOLE=n
CONFIG_HVC_DRIVER=y
CONFIG_HVC_IRQ=y

# Timers
CONFIG_HZ=100
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=n

# APIC
CONFIG_X86_LOCAL_APIC=n
CONFIG_X86_IO_APIC=n
CONFIG_X86_REBOOTFIXUPS=n

# PCI / ACPI (disabled)
CONFIG_PCI=n
CONFIG_ACPI=n

# USB / HID / Sound / DRM (all disabled)
CONFIG_USB=n
CONFIG_HID=n
CONFIG_SOUND=n
CONFIG_DRM=n

# Crypto (minimal — needed by some netfilter code)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_HASH=y
CONFIG_CRYPTO_NULL=y

# GCC plugins (disable for reproducibility)
CONFIG_GCC_PLUGINS=n
CONFIG_GCC_PLUGIN_RANDSTRUCT=n
